@InProceedings{10.1007/978-3-540-45146-4_27,
  author="Ishai, Yuval and Sahai, Amit and Wagner, David",
  editor="Boneh, Dan",
  title="Private Circuits: Securing Hardware against Probing Attacks",
  booktitle="Advances in Cryptology - CRYPTO 2003",
  year="2003",
  publisher="Springer Berlin Heidelberg",
  address="Berlin, Heidelberg",
  pages="463--481",
  abstract="Can you guarantee secrecy even if an adversary can eavesdrop on your brain? We consider the problem of protecting privacy in circuits, when faced with an adversary that can access a bounded number of wires in the circuit. This question is motivated by side channel attacks, which allow an adversary to gain partial access to the inner workings of hardware. Recent work has shown that side channel attacks pose a serious threat to cryptosystems implemented in embedded devices. In this paper, we develop theoretical foundations for security against side channels. In particular, we propose several efficient techniques for building private circuits resisting this type of attacks. We initiate a systematic study of the complexity of such private circuits, and in contrast to most prior work in this area provide a formal threat model and give proofs of security for our constructions.",
  isbn="978-3-540-45146-4"
}

@InProceedings{10.1007/978-3-030-29959-0_15,
  author    = "Barthe, Gilles and Bela{\"i}d, Sonia and Cassiers, Ga{\"e}tan and Fouque, Pierre-Alain and Gr{\'e}goire Benjamin and Standaert, Fran{\c{c}}ois-Xavier",
  editor    = "Sako, Kazue and Schneider, Steve A. and Ryan, Peter Y. A.",
  title     = "maskVerif: Automated Verification of Higher-Order Masking in Presence of Physical Defaults",
  booktitle = "Computer Security -- ESORICS 2019",
  year      = "2019",
  publisher = "Springer International Publishing",
  address   = "Cham",
  pages     = "300--318",
  volume    = "11735",
  series    = "Lecture Notes in Computer Science",
  abstract  = "Masking is a popular countermeasure to defeat side-channel attacks. Several works have investigated formal verification of masked implementations, mostly in a value-based leakage model, i.e. assuming the leakage of every computation only depends on its input/output values. However, in practice, the physical leakage of a computation may depend on the way it is computed, and it may include transition-based or glitch-related leakage. In this paper, we present maskVerif, a tool for formally verifying security of masked implementations in the presence of physical defaults, including glitches and transitions.",
  isbn      = "978-3-030-29959-0",
  doi       = "10.1007/978-3-030-29959-0_15"
}

